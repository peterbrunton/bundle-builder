{%- assign heading = block.settings.heading | strip -%}
{%- assign description = block.settings.description | strip -%}
{%- assign parent_product = block.settings.parent_product -%}
{%- assign parent_variant_id = '' -%}
{%- if parent_product != blank -%}
  {%- assign resolved_parent_variant = blank -%}
  {%- for variant in parent_product.variants -%}
    {%- if variant.available -%}
      {%- assign resolved_parent_variant = variant -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if resolved_parent_variant == blank and parent_product.variants.size > 0 -%}
    {%- assign resolved_parent_variant = parent_product.variants.first -%}
  {%- endif -%}
  {%- if resolved_parent_variant != blank -%}
    {%- assign parent_variant_id = resolved_parent_variant.id -%}
  {%- endif -%}
{%- endif -%}

{%- assign rulebooks = shop.metafields.bundle_builder.rulebooks.value -%}

{%- assign selected_rulebook = blank -%}
{%- assign bundle_config_id = block.settings.bundle_config_id -%}
{%- if bundle_config_id != blank -%}
  {%- for rb in rulebooks -%}
    {%- if rb.id == bundle_config_id -%}
      {%- assign selected_rulebook = rb -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- if selected_rulebook == blank -%}
  {%- for rb in rulebooks -%}
    {%- if rb.isDefault -%}
      {%- assign selected_rulebook = rb -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- if selected_rulebook == blank -%}
  {%- assign selected_rulebook = rulebooks.first -%}
{%- endif -%}
{%- assign fallback_categories_json = '[{"key":"full","label":"Full","min":1,"max":2},{"key":"small","label":"Small","min":2,"max":4}]' -%}

<div
  class="bundle-builder"
  style="
    --bb-bg: {{ block.settings.background_color }};
    --bb-surface: {{ block.settings.surface_color }};
    --bb-surface-soft: {{ block.settings.surface_soft_color }};
    --bb-ink: {{ block.settings.text_color }};
    --bb-muted: {{ block.settings.muted_text_color }};
    --bb-accent: {{ block.settings.accent_color }};
    --bb-button-ink: {{ block.settings.button_text_color }};
    --bb-border: {{ block.settings.border_color }};
    --bb-main-border-color: {{ block.settings.main_section_border_color }};
    --bb-main-border-width: {{ block.settings.main_section_border_width }}px;
    --bb-footer-border-color: {{ block.settings.footer_section_border_color }};
    --bb-footer-border-width: {{ block.settings.footer_section_border_width }}px;
    --bb-radius: {{ block.settings.corner_radius }}px;
    --bb-shadow-opacity: {{ block.settings.shadow_opacity | divided_by: 100.0 }};
  "
  data-bundle-version="v1"
  data-bundle-config-id="{{ selected_rulebook.id | default: 'bundle-config-1' }}"
  data-categories="{% if selected_rulebook != blank %}{{ selected_rulebook.categories | json | escape }}{% else %}{{ fallback_categories_json | escape }}{% endif %}"
  data-add-text="Add to Bundle"
  data-remove-text="Remove from Bundle"
  data-parent-variant-id="{{ parent_variant_id }}"
  data-proxy-path="{{ block.settings.proxy_path | default: '/apps/bundle-builder-1' }}"
  data-currency-code="{{ shop.currency }}"
>
  {%- if heading != blank or description != blank -%}
    <div class="bundle-builder__header">
      {%- if heading != blank -%}
        <h2 class="bundle-builder__title">{{ heading | escape }}</h2>
      {%- endif -%}
      {%- if description != blank -%}
        <p class="bundle-builder__description">{{ description | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="bundle-builder__body">
    <div class="bundle-builder__panels">
      {%- if selected_rulebook != blank -%}
        {%- for category in selected_rulebook.categories -%}
          {%- assign min_count = category.min | default: 0 -%}
          {%- assign max_count = category.max -%}
          {%- assign products_key = 'category_' | append: forloop.index | append: '_products' -%}
          {%- assign products_list = block.settings[products_key] -%}
          <div class="bundle-builder__panel">
            <div class="bundle-builder__panel-header">
              <h3 class="bundle-builder__panel-title">{{ category.label | escape }}</h3>
              <span class="bundle-builder__panel-subtitle">
                {%- if max_count -%}
                  Select {{ min_count }}-{{ max_count }}
                {%- else -%}
                  Select {{ min_count }}+
                {%- endif -%}
              </span>
            </div>
            <ul class="bundle-builder__list" data-role-list="{{ category.key }}">
              {%- assign has_renderable_products = false -%}
              {%- if products_list and products_list.size > 0 -%}
                {%- for product in products_list -%}
                  {%- assign variant = product.selected_or_first_available_variant -%}
                  {%- if variant != blank and variant.available -%}
                    {%- assign has_renderable_products = true -%}
                    <li
                      class="bundle-builder__item"
                      data-variant-id="{{ variant.id }}"
                      data-role="{{ category.key }}"
                      data-price="{{ variant.price | divided_by: 100.0 }}"
                      data-price-cents="{{ variant.price }}"
                      data-compare-at-cents="{{ variant.compare_at_price | default: 0 }}"
                    >
                      <div class="bundle-builder__item-main">
                        {%- if product.featured_image -%}
                          <img
                            width="100"
                            height="125"
                            class="bundle-builder__item-image"
                            src="{{ product.featured_image | image_url: width: 100 }}"
                            alt="{{ product.title | escape }}"
                            loading="lazy"
                          >
                        {%- endif -%}
                        <div class="bundle-builder__item-info">
                          <span class="bundle-builder__item-title">{{ product.title | escape }}</span>
                          <span class="bundle-builder__item-meta">{{ variant.title | escape }}</span>
                          <div class="bundle-builder__item-pricing" data-item-pricing>
                            <span class="bundle-builder__item-price-current" data-item-price-current>
                              {% if variant.compare_at_price and variant.compare_at_price > 0 %}
                                {{ variant.compare_at_price | money }}
                              {% else %}
                                {{ variant.price | money }}
                              {% endif %}
                            </span>
                            <span class="bundle-builder__item-price-compare" data-item-price-compare hidden>
                              {% if variant.compare_at_price and variant.compare_at_price > 0 %}
                                {{ variant.compare_at_price | money }}
                              {% else %}
                                {{ variant.price | money }}
                              {% endif %}
                            </span>
                          </div>
                          <button
                            type="button"
                            class="button button-secondary bundle-builder__item-toggle"
                            data-action="toggle"
                          >
                            Add to Bundle
                          </button>
                        </div>
                      </div>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if has_renderable_products == false -%}
                <li class="bundle-builder__empty">No products configured</li>
              {%- endif -%}
            </ul>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign fallback_labels = 'Full,Small' | split: ',' -%}
        {%- assign fallback_keys = 'full,small' | split: ',' -%}
        {%- assign fallback_mins = '1,2' | split: ',' -%}
        {%- assign fallback_maxes = '2,4' | split: ',' -%}
        {%- for label in fallback_labels -%}
          {%- assign idx = forloop.index0 -%}
          {%- assign key = fallback_keys[idx] -%}
          {%- assign min_count = fallback_mins[idx] -%}
          {%- assign max_count = fallback_maxes[idx] -%}
          {%- assign products_key = 'category_' | append: forloop.index | append: '_products' -%}
          {%- assign products_list = block.settings[products_key] -%}
          <div class="bundle-builder__panel">
            <div class="bundle-builder__panel-header">
              <h3 class="bundle-builder__panel-title">{{ label | escape }}</h3>
              <span class="bundle-builder__panel-subtitle">Select {{ min_count }}-{{ max_count }}</span>
            </div>
            <ul class="bundle-builder__list" data-role-list="{{ key }}">
              {%- assign has_renderable_products = false -%}
              {%- if products_list and products_list.size > 0 -%}
                {%- for product in products_list -%}
                  {%- assign variant = product.selected_or_first_available_variant -%}
                  {%- if variant != blank and variant.available -%}
                    {%- assign has_renderable_products = true -%}
                    <li
                      class="bundle-builder__item"
                      data-variant-id="{{ variant.id }}"
                      data-role="{{ key }}"
                      data-price="{{ variant.price | divided_by: 100.0 }}"
                      data-price-cents="{{ variant.price }}"
                      data-compare-at-cents="{{ variant.compare_at_price | default: 0 }}"
                    >
                      <div class="bundle-builder__item-main">
                        {%- if product.featured_image -%}
                          <img
                            width="100"
                            height="125"
                            class="bundle-builder__item-image"
                            src="{{ product.featured_image | image_url: width: 100 }}"
                            alt="{{ product.title | escape }}"
                            loading="lazy"
                          >
                        {%- endif -%}
                        <div class="bundle-builder__item-info">
                          <span class="bundle-builder__item-title">{{ product.title | escape }}</span>
                          <span class="bundle-builder__item-meta">{{ variant.title | escape }}</span>
                          <div class="bundle-builder__item-pricing" data-item-pricing>
                            <span class="bundle-builder__item-price-current" data-item-price-current>
                              {% if variant.compare_at_price and variant.compare_at_price > 0 %}
                                {{ variant.compare_at_price | money }}
                              {% else %}
                                {{ variant.price | money }}
                              {% endif %}
                            </span>
                            <span class="bundle-builder__item-price-compare" data-item-price-compare hidden>
                              {% if variant.compare_at_price and variant.compare_at_price > 0 %}
                                {{ variant.compare_at_price | money }}
                              {% else %}
                                {{ variant.price | money }}
                              {% endif %}
                            </span>
                          </div>
                          <button
                            type="button"
                            class="button button-secondary bundle-builder__item-toggle"
                            data-action="toggle"
                          >
                            Add to Bundle
                          </button>
                        </div>
                      </div>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if has_renderable_products == false -%}
                <li class="bundle-builder__empty">No products configured</li>
              {%- endif -%}
            </ul>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="bundle-builder__footer">
      <div class="bundle-builder__preview">
        <div class="bundle-builder__preview-header">
          <span class="bundle-builder__preview-title">Your bundle</span>
          <span class="bundle-builder__preview-count" data-bundle-count>0</span>
        </div>
        <div class="bundle-builder__preview-grid" data-bundle-preview></div>
      </div>

      <div class="bundle-builder__offers">
        <p class="bundle-builder__offers-title">Bundle offers</p>
        {%- assign tiers = selected_rulebook.tiers | sort: 'percent' -%}
        {%- if tiers and tiers.size > 0 and selected_rulebook != blank -%}
          {%- assign tiers_json = tiers | json | escape -%}
          <ul class="bundle-builder__offers-list" data-bundle-tiers="{{ tiers_json }}">
            {%- for tier in tiers -%}
              {%- capture offer_parts -%}
                {%- for category in selected_rulebook.categories -%}
                  {%- assign req = tier.requirements[category.key] -%}
                  {%- if forloop.index > 1 -%} & {%- endif -%}
                  {%- assign min = req.min | default: 0 -%}
                  {%- assign max = req.max -%}
                  {%- if max -%}
                    {{ min }}-{{ max }} {{ category.label }}
                  {%- else -%}
                    {{ min }} {{ category.label }}
                  {%- endif -%}
                {%- endfor -%}
              {%- endcapture -%}
              <li data-tier="{{ tier.percent }}">Pick {{ offer_parts | strip }} → {{ tier.percent }}% off</li>
            {%- endfor -%}
          </ul>
        {%- else -%}
          <ul class="bundle-builder__offers-list" data-bundle-tiers="[]">
            <li>No offers configured yet.</li>
          </ul>
        {%- endif -%}
      </div>

      <div class="bundle-builder__pricing" data-bundle-pricing hidden>
        <div class="bundle-builder__pricing-row">
          <span>Initial total</span>
          <span data-bundle-price-base>--</span>
        </div>
        <div class="bundle-builder__pricing-row">
          <span>Bundle total</span>
          <span data-bundle-price-discounted>--</span>
        </div>
        <div class="bundle-builder__pricing-row">
          <span>Discounted / unit</span>
          <span data-bundle-price-per-unit>--</span>
        </div>
      </div>

      <div
        class="bundle-builder__status"
        data-bundle-status
        data-ready-text="{{ 'bundle_builder.status_ready' | t | escape }}"
        data-invalid-text="{{ 'bundle_builder.status_invalid' | t | escape }}"
      >
        {{ 'bundle_builder.status_idle' | t }}
      </div>
      <button type="button" class="button bundle-builder__cta" data-bundle-action="commit">
        {{ 'bundle_builder.cta_commit' | t }}
      </button>
      <div class="bundle-builder__proxy-warning" data-bundle-proxy-warning hidden></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:bundle_builder.name",
  "target": "section",
  "stylesheet": "bundle-builder.css",
  "javascript": "bundle-builder.js",
  "settings": [
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ECECEC"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Panel color",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "surface_soft_color",
      "label": "Sub-panel color",
      "default": "#FAFAFA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading text color",
      "default": "#111315"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Body text color",
      "default": "#4D4D4D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button color",
      "default": "#111315"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#DCDCDC"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:bundle_builder.settings.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:bundle_builder.settings.description"
    },
    {
      "type": "color",
      "id": "main_section_border_color",
      "label": "Main section border color",
      "default": "#DCDCDC"
    },
    {
      "type": "range",
      "id": "main_section_border_width",
      "label": "Main section border width",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 1
    },
    {
      "type": "color",
      "id": "footer_section_border_color",
      "label": "Footer section border color",
      "default": "#DCDCDC"
    },
    {
      "type": "range",
      "id": "footer_section_border_width",
      "label": "Footer section border width",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 1
    },
    {
      "type": "text",
      "id": "bundle_config_id",
      "label": "Bundle configuration ID"
    },
    {
      "type": "product",
      "id": "parent_product",
      "label": "Bundle parent product"
    },
    {
      "type": "product_list",
      "id": "category_1_products",
      "label": "Category 1 products"
    },
    {
      "type": "product_list",
      "id": "category_2_products",
      "label": "Category 2 products"
    },
    {
      "type": "product_list",
      "id": "category_3_products",
      "label": "Category 3 products"
    },
    {
      "type": "product_list",
      "id": "category_4_products",
      "label": "Category 4 products"
    },
    {
      "type": "product_list",
      "id": "category_5_products",
      "label": "Category 5 products"
    },
    {
      "type": "text",
      "id": "proxy_path",
      "label": "App proxy path",
      "default": "/apps/bundle-builder-1"
    }
  ],
  "enabled_on": {
    "templates": ["product", "collection", "index", "page"]
  }
}
{% endschema %}
